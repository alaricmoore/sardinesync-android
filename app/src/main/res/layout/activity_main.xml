<?xml version="1.0" encoding="utf-8"?>
<!--
  The whole app is the tracker website. A small semi-transparent "⋮" button
  floats in the top-right (like the iOS app's floating gear) and opens a
  PopupMenu of dev-only tools; the friend just ignores it.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"><!-- inset below the status/nav bars (edge-to-edge on Android 15) -->

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <Button
        android:id="@+id/menuButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:alpha="0.55"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="⋮"
        android:textColor="@android:color/white"
        android:textSize="20sp" />
</FrameLayout>
